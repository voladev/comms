# Driver selection
COMMS_DRIVER=telegram

# Default recipient (chat_id for the active driver)
COMMS_DEFAULT_CHAT_ID=

# Named users: COMMS_USER_<name>=<platform_chat_id>
COMMS_USER_olga=
COMMS_USER_igor=

# ── Telegram driver ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Legacy aliases (still supported for backwards compat with notify.sh)
# TELEGRAM_USER_olga=
# TELEGRAM_USER_igor=
# TELEGRAM_CHAT_ID=
